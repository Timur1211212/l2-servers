{
  "name": "l2-servers-catalog",
  "version": "2.0.0",
  "description": "Полноценный каталог серверов Lineage 2 с админ-панелью, отзывами, рейтингами и SEO оптимизацией",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "pm2-start": "pm2 start server.js --name l2-servers",
    "pm2-stop": "pm2 stop l2-servers",
    "pm2-restart": "pm2 restart l2-servers",
    "pm2-delete": "pm2 delete l2-servers",
    "seed": "node seed.js"
  },
  "keywords": [
    "lineage2",
    "l2",
    "servers",
    "catalog",
    "reviews",
    "ratings",
    "seo",
    "mongodb",
    "express"
  ],
  "author": "L2 Servers Catalog",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "canvas": "^3.2.3",
    "compression": "^1.8.1",
    "connect-mongo": "^5.1.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "joi": "^18.1.2",
    "mongoose": "^8.0.0",
    "node-cache": "^5.1.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
